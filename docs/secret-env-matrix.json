{
  "_comment": [
    "Source of truth for environment variable name auditing and rotation routing.",
    "This file must never contain real secret values."
  ],
  "version": 1,
  "railway": {
    "project_id_secret": "RAILWAY_PROJECT_ID",
    "environment_id_secret": "RAILWAY_ENVIRONMENT_ID",
    "services": {
      "api": {
        "enforcement": "strict",
        "service_id_secret": "RAILWAY_SERVICE_API_ID",
        "required": [
          "ENVIRONMENT",
          "DATABASE_URL",
          "REDIS_URL",
          "FERNET_KEY",
          "GITHUB_APP_ID",
          "GITHUB_WEBHOOK_SECRET",
          "GITHUB_CLIENT_ID",
          "GITHUB_CLIENT_SECRET",
          "APP_PRIVATE_KEY_PEM",
          "API_ACCESS_KEY",
          "DASHBOARD_USER_JWT_SECRET",
          "DASHBOARD_USER_JWT_AUDIENCE",
          "DASHBOARD_USER_JWT_ISSUER",
          "ADMIN_RETRY_API_KEY",
          "WEB_APP_URL"
        ],
        "optional": [
          "ANTHROPIC_API_KEY",
          "OPENAI_API_KEY",
          "GEMINI_API_KEY",
          "SENTRY_DSN",
          "LANGFUSE_PUBLIC_KEY",
          "LANGFUSE_SECRET_KEY",
          "LANGFUSE_HOST",
          "R2_ENDPOINT_URL",
          "R2_BUCKET",
          "R2_ACCESS_KEY_ID",
          "R2_SECRET_ACCESS_KEY",
          "R2_REGION",
          "R2_SNAPSHOT_PREFIX"
        ]
      },
      "worker": {
        "enforcement": "strict",
        "service_id_secret": "RAILWAY_SERVICE_WORKER_ID",
        "required": [
          "ENVIRONMENT",
          "DATABASE_URL",
          "REDIS_URL",
          "FERNET_KEY",
          "GITHUB_APP_ID",
          "GITHUB_WEBHOOK_SECRET",
          "APP_PRIVATE_KEY_PEM"
        ],
        "optional": [
          "ANTHROPIC_API_KEY",
          "OPENAI_API_KEY",
          "GEMINI_API_KEY",
          "SENTRY_DSN",
          "LANGFUSE_PUBLIC_KEY",
          "LANGFUSE_SECRET_KEY",
          "LANGFUSE_HOST",
          "R2_ENDPOINT_URL",
          "R2_BUCKET",
          "R2_ACCESS_KEY_ID",
          "R2_SECRET_ACCESS_KEY",
          "R2_REGION",
          "R2_SNAPSHOT_PREFIX",
          "ADMIN_RETRY_API_KEY",
          "GITHUB_CLIENT_ID",
          "GITHUB_CLIENT_SECRET"
        ]
      },
      "postgres": {
        "enforcement": "advisory",
        "service_id_secret": "RAILWAY_SERVICE_POSTGRES_ID",
        "required": [],
        "optional": [],
        "notes": "Managed by provider templates; included for inventory completeness."
      },
      "redis": {
        "enforcement": "advisory",
        "service_id_secret": "RAILWAY_SERVICE_REDIS_ID",
        "required": [],
        "optional": [],
        "notes": "Managed by provider templates; included for inventory completeness."
      }
    }
  },
  "vercel": {
    "project_id_secret": "VERCEL_PROJECT_ID",
    "team_id_secret": "VERCEL_TEAM_ID",
    "environments": {
      "production": {
        "enforcement": "strict",
        "required": [
          "GITHUB_CLIENT_ID",
          "GITHUB_CLIENT_SECRET",
          "AUTH_SESSION_SECRET",
          "API_URL",
          "API_ACCESS_KEY"
        ],
        "optional": [
          "DASHBOARD_USER_JWT_SECRET",
          "DASHBOARD_USER_JWT_AUDIENCE",
          "DASHBOARD_USER_JWT_ISSUER",
          "UPSTASH_REDIS_REST_URL",
          "UPSTASH_REDIS_REST_TOKEN"
        ]
      },
      "preview": {
        "enforcement": "strict",
        "required": [
          "GITHUB_CLIENT_ID",
          "GITHUB_CLIENT_SECRET",
          "AUTH_SESSION_SECRET",
          "API_URL",
          "API_ACCESS_KEY"
        ],
        "optional": [
          "DASHBOARD_USER_JWT_SECRET",
          "DASHBOARD_USER_JWT_AUDIENCE",
          "DASHBOARD_USER_JWT_ISSUER",
          "UPSTASH_REDIS_REST_URL",
          "UPSTASH_REDIS_REST_TOKEN"
        ]
      },
      "development": {
        "enforcement": "strict",
        "required": [
          "GITHUB_CLIENT_ID",
          "GITHUB_CLIENT_SECRET",
          "AUTH_SESSION_SECRET",
          "API_URL",
          "API_ACCESS_KEY"
        ],
        "optional": [
          "DASHBOARD_USER_JWT_SECRET",
          "DASHBOARD_USER_JWT_AUDIENCE",
          "DASHBOARD_USER_JWT_ISSUER",
          "UPSTASH_REDIS_REST_URL",
          "UPSTASH_REDIS_REST_TOKEN"
        ]
      }
    }
  },
  "rotation_groups": {
    "api_access_key": {
      "mode": "automated",
      "variables": [
        {
          "name": "API_ACCESS_KEY",
          "railway_services": [
            "api"
          ],
          "vercel_environments": [
            "production",
            "preview",
            "development"
          ]
        }
      ]
    },
    "dashboard_jwt_secret": {
      "mode": "automated",
      "variables": [
        {
          "name": "DASHBOARD_USER_JWT_SECRET",
          "railway_services": [
            "api"
          ],
          "vercel_environments": [
            "production",
            "preview",
            "development"
          ]
        }
      ]
    },
    "auth_session_secret": {
      "mode": "automated",
      "variables": [
        {
          "name": "AUTH_SESSION_SECRET",
          "railway_services": [],
          "vercel_environments": [
            "production",
            "preview",
            "development"
          ]
        }
      ]
    },
    "admin_retry_api_key": {
      "mode": "automated",
      "variables": [
        {
          "name": "ADMIN_RETRY_API_KEY",
          "railway_services": [
            "api",
            "worker"
          ],
          "vercel_environments": []
        }
      ]
    },
    "fernet": {
      "mode": "manual_only",
      "blocked_reason": "FERNET_KEY requires token re-encryption or forced re-auth plan."
    },
    "github_oauth": {
      "mode": "manual_only",
      "blocked_reason": "Rotate in GitHub OAuth app first, then distribute coordinated values."
    },
    "app_private_key_pem": {
      "mode": "manual_only",
      "blocked_reason": "Requires key overlap in GitHub App settings and verification before revocation."
    },
    "webhook_secret": {
      "mode": "manual_only",
      "blocked_reason": "Must be coordinated with GitHub webhook sender and all receivers."
    }
  }
}
