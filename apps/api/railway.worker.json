{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": ". /opt/venv/bin/activate && pip install ."
  },
  "deploy": {
    "startCommand": "python -m arq app.queue.worker.WorkerSettings",
    "healthcheckPath": null,
    "restartPolicyType": "ON_FAILURE"
  }
}
