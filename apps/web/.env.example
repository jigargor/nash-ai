# Copy to .env.local in this directory (apps/web), or set the same vars in the repo-root `.env.local`.
# `next.config.ts` loads repo-root `.env*` first so one file can serve API + web in dev.

# GitHub OAuth App (same Client ID/secret as in root .env for the API, or a dedicated OAuth app)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Session cookie signing (generate: openssl rand -base64 32)
AUTH_SESSION_SECRET=
