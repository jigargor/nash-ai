# Copy to .env.local in this directory (apps/web), or set the same vars in the repo-root `.env.local`.
# `next.config.ts` loads repo-root `.env*` first so one file can serve API + web in dev.

# GitHub OAuth App (same Client ID/secret as in root .env for the API, or a dedicated OAuth app)
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# Session cookie signing (generate: openssl rand -base64 32)
AUTH_SESSION_SECRET="replace_with_32_byte_random_secret"

# BFF proxy: browser calls /api/v1/* on this Next app; these forward to the FastAPI backend (required on Vercel).
# Must match the same value as API_ACCESS_KEY on Railway.
# Local: http://localhost:8000. Production (Vercel → Railway): use https://your-service.up.railway.app (not http — avoids redirect/CORS issues).
API_URL=http://localhost:8000
API_ACCESS_KEY=change-me
# Do not set NEXT_PUBLIC_API_BASE for production on Vercel — keep API calls same-origin to avoid CSP blocks.
# NEXT_PUBLIC_API_BASE=
