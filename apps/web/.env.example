# Copy to .env.local in this directory (apps/web).
# Next.js loads .env.local from the app root, not the monorepo root.

# GitHub OAuth App (same Client ID/secret as in root .env for the API, or a dedicated OAuth app)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Session cookie signing (generate: openssl rand -base64 32)
AUTH_SESSION_SECRET=
