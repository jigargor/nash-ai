{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "nash: uvicorn",
      "type": "shell",
      "command": "python -m uvicorn app.main:app --reload --port 8000",
      "options": {
        "cwd": "${workspaceFolder}/apps/api/src"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "nash"
      }
    },
    {
      "label": "nash: arq",
      "type": "shell",
      "command": "python -m arq app.queue.worker.WorkerSettings",
      "options": {
        "cwd": "${workspaceFolder}/apps/api/src"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "nash"
      }
    },
    {
      "label": "nash: smee",
      "type": "shell",
      "command": "npx smee-client --url \"${env:SMEE_URL}\" --target http://localhost:8000/webhooks/github",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "nash"
      }
    },
    {
      "label": "nash: web",
