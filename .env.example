# GitHub App
GITHUB_APP_ID=123456
GITHUB_WEBHOOK_SECRET=your_32_byte_hex_here
GITHUB_PRIVATE_KEY_PATH=./private-key.pem

# GitHub OAuth (dashboard login)
GITHUB_CLIENT_ID=Iv1.abc123
GITHUB_CLIENT_SECRET=your_client_secret

# Database / Redis
DATABASE_URL=postgresql+asyncpg://dev:dev@localhost:5433/codereview
# Production example (TLS required): postgresql+asyncpg://user:pass@host:5432/dbname?ssl=require
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_COMMAND_TIMEOUT_SECONDS=30
# DB_STATEMENT_TIMEOUT_MS=30000
# DB_REQUIRE_SSL_IN_PRODUCTION=true
REDIS_URL=redis://localhost:6379

# Token encryption (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=your_fernet_key_here

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# App
ENVIRONMENT=development
LOG_WEBHOOK_PAYLOADS=false
# TEST_DATABASE_URL=postgresql+asyncpg://dev:dev@localhost:5433/codereview_test
