# GitHub App
GITHUB_APP_ID=123456
GITHUB_WEBHOOK_SECRET=your_32_byte_hex_here
# Prefer this on hosted platforms (Railway): full PEM value, keep escaped \n if single-line.
# APP_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
APP_PRIVATE_KEY_PEM_PATH=./private-key.pem

# GitHub OAuth (dashboard login; Next.js uses these. API/ARQ worker may omit if unset.)
GITHUB_CLIENT_ID=Iv1.abc123
GITHUB_CLIENT_SECRET=your_client_secret

# Database / Redis
DATABASE_URL="postgresql+asyncpg://dev:dev@localhost:5433/codereview?ssl=require"
# Plaintext local fallback (if Postgres SSL is intentionally disabled): 
# DATABASE_URL=postgresql+asyncpg://dev:dev@localhost:5433/codereview
# Production example (TLS required): postgresql+asyncpg://user:pass@host:5432/dbname?ssl=require
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20  
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_COMMAND_TIMEOUT_SECONDS=30
# asyncpg connection establishment timeout (seconds); lower avoids long Railway 502s when DB is down.
# DB_CONNECT_TIMEOUT_SECONDS=15
# DB_STATEMENT_TIMEOUT_MS=30000
# DB_REQUIRE_SSL_IN_PRODUCTION=true
REDIS_URL=redis://localhost:6379

# Token encryption (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=your_fernet_key_here

# LLM providers (BYOK): add API keys in the dashboard; do not commit provider secrets here.
# Optional defaults when a provider key is configured:
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-5
OPENAI_DEFAULT_MODEL=gpt-5.5
GEMINI_DEFAULT_MODEL=gemini-2.5-pro

# App
ENVIRONMENT=development
LOG_WEBHOOK_PAYLOADS=false
ADMIN_RETRY_API_KEY=change-me
API_ACCESS_KEY=change-me
# Dashboard user JWT (BFF -> API identity propagation)
# Use a long random secret (>=32 chars recommended).
DASHBOARD_USER_JWT_SECRET=change-me-to-a-long-random-secret
DASHBOARD_USER_JWT_AUDIENCE=dashboard-api
DASHBOARD_USER_JWT_ISSUER=nash-web-dashboard
ENABLE_REVIEWS=true
REVIEWS_PER_HOUR_LIMIT=30
DAILY_TOKEN_BUDGET_PER_INSTALLATION=10000000
# Frontend origin for API CORS (exact match, no trailing slash). Required on Railway if the browser calls the API directly.
WEB_APP_URL=http://localhost:3000
# API base URL used by the Next.js BFF auth callback.
API_URL=http://localhost:8000
# Cloudflare Turnstile (protect explicit rerun/retry submissions)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
# Snapshot lifecycle + archive controls
SNAPSHOT_RETENTION_DAYS=30
SNAPSHOT_ARCHIVE_BATCH_SIZE=100
# Optional Cloudflare R2 archive for expired snapshots
# R2_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
# R2_BUCKET=nash-review-snapshots
# R2_ACCESS_KEY_ID=your_r2_access_key_id
# R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# R2_REGION=auto
# R2_SNAPSHOT_PREFIX=review-snapshots
# When R2_* credentials are set, required: UTC date you last rotated those keys (ISO-8601, e.g. 2026-04-29).
# R2_CREDENTIALS_ROTATED_AT=2026-04-29
# Max age before API/worker refuse to start (defaults: production 30d, non-production 90d).
# R2_ACCESS_KEY_MAX_AGE_DAYS_PRODUCTION=30
# R2_ACCESS_KEY_MAX_AGE_DAYS_DEVELOPMENT=90
# SENTRY_DSN=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
# TEST_DATABASE_URL=postgresql+asyncpg://dev:dev@localhost:5433/codereview_test?ssl=require
