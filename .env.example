# GitHub App
GITHUB_APP_ID=123456
GITHUB_WEBHOOK_SECRET=your_32_byte_hex_here
GITHUB_PRIVATE_KEY_PATH=./private-key.pem

# GitHub OAuth (dashboard login)
GITHUB_CLIENT_ID=Iv1.abc123
GITHUB_CLIENT_SECRET=your_client_secret

# Database / Redis
DATABASE_URL=postgresql+asyncpg://dev:dev@localhost:5433/codereview
REDIS_URL=redis://localhost:6379

# Token encryption (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=your_fernet_key_here

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# App
ENVIRONMENT=development
